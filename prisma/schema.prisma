generator client {
  provider        = "prisma-client"
  previewFeatures = ["relationJoins"]
  output          = "./generated"
}

datasource db {
  provider = "cockroachdb"
}

model User {
  id                   String        @id @default(cuid())
  name                 String?
  email                String        @unique
  emailVerified        DateTime?     @map("email_verified")
  image                String?
  accounts             Account[]
  session              Session[]
  role                 Role          @default(USER)
  notes                Note[]        @relation("UserNotes")
  comments             Comment[]
  viewHistory          ViewHistory[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  forumPosts           ForumPost[]
  pastPapers           PastPaper[]   @relation("UserPastPapers")
  bookmarkedNotes      Note[]        @relation("UserBookmarkedNotes")
  bookmarkedPastPapers PastPaper[]   @relation("UserBookmarkedPastPapers")
  bookmarkedResources  Subject[]     @relation("UserBookmarkedResources")
  bookmarkedForumPosts ForumPost[]   @relation("UserBookmarkedForumPosts")
  bookmarkedSyllabus   syllabi[]     @relation("UserBookmarkedSyllabus")
  votes                Vote[]
  studyChats           StudyChat[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  // for password-based login
  passwordHash String? // bcrypt hash
  passwordSalt String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_user_id_idx")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@index([expires], map: "sessions_expires_idx")
  @@map("sessions")
}

enum Role {
  USER
  MODERATOR
}

enum ExamType {
  CAT_1
  CAT_2
  FAT
  MODEL_CAT_1
  MODEL_CAT_2
  MODEL_FAT
  MID
  QUIZ
  CIA
  OTHER
}

enum Semester {
  FALL
  WINTER
  SUMMER
  WEEKEND
  UNKNOWN
}

enum Campus {
  VELLORE
  CHENNAI
  AP
  BHOPAL
  BANGALORE
  MAURITIUS
}

model Course {
  id            String         @id @default(cuid())
  code          String         @unique
  title         String
  aliases       String[]
  papers        PastPaper[]
  notes         Note[]
  upcomingExams UpcomingExam[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([title])
}

model UpcomingExam {
  id          String    @id @default(cuid())
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slots       String[]
  examType    ExamType?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([courseId])
  @@index([scheduledAt])
  @@index([courseId, scheduledAt])
  @@index([scheduledAt, createdAt])
}

model Note {
  id           String        @id @default(cuid())
  title        String
  author       User          @relation(fields: [authorId], references: [id], name: "UserNotes")
  authorId     String
  fileUrl      String
  thumbNailUrl String?
  isClear      Boolean       @default(false)
  tags         Tag[]
  courseId     String?
  course       Course?       @relation(fields: [courseId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bookmarkedBy User[]        @relation("UserBookmarkedNotes")
  ViewHistory  ViewHistory[]
  studyChats   StudyChat[]

  @@index([isClear, createdAt])
  @@index([createdAt])
  @@index([authorId])
  @@index([courseId])
  @@index([courseId, isClear, createdAt])
  @@index([courseId, isClear, updatedAt])
}

model ViewHistory {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  pastPaper   PastPaper? @relation(fields: [pastPaperId], references: [id])
  pastPaperId String?
  note        Note?      @relation(fields: [noteId], references: [id])
  noteId      String?
  forumPost   ForumPost? @relation(fields: [forumPostId], references: [id])
  forumPostId String?
  subject     Subject?   @relation(fields: [subjectId], references: [id])
  subjectId   String?
  viewedAt    DateTime   @updatedAt
  count       Int        @default(1)
  syllabi     syllabi?   @relation(fields: [syllabusId], references: [id])
  syllabusId  String?

  @@unique([userId, pastPaperId])
  @@unique([userId, noteId])
  @@unique([userId, forumPostId])
  @@unique([userId, subjectId])
  @@unique([userId, syllabusId])
  @@index([userId, viewedAt])
  @@index([pastPaperId])
  @@index([noteId])
  @@index([forumPostId])
  @@index([subjectId])
  @@index([syllabusId])
}

model Forum {
  id         String      @id @default(cuid())
  courseName String
  tags       Tag[]
  posts      ForumPost[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model ForumPost {
  id            String        @id @default(cuid())
  title         String
  author        User          @relation(fields: [authorId], references: [id])
  authorId      String
  forum         Forum         @relation(fields: [forumId], references: [id])
  forumId       String
  description   String        @default("")
  comments      Comment[]
  tags          Tag[]
  upvoteCount   Int           @default(0)
  downvoteCount Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bookmarkedBy  User[]        @relation("UserBookmarkedForumPosts")
  viewHistory   ViewHistory[]
  votes         Vote[]

  @@index([createdAt])
  @@index([authorId])
  @@index([forumId, createdAt])
}

model Vote {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  forumPostId String
  forumPost   ForumPost @relation(fields: [forumPostId], references: [id])
  type        VoteType
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, forumPostId])
  @@index([forumPostId])
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

model Comment {
  id          String    @id @default(cuid())
  content     String
  author      User      @relation(fields: [authorId], references: [id])
  authorId    String
  forumPost   ForumPost @relation(fields: [forumPostId], references: [id])
  forumPostId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([authorId])
  @@index([forumPostId, createdAt])
}

model PastPaper {
  id               String        @id @default(cuid())
  title            String
  fileUrl          String
  thumbNailUrl     String?
  tags             Tag[]
  author           User          @relation(fields: [authorId], references: [id], name: "UserPastPapers")
  authorId         String
  isClear          Boolean       @default(false)
  courseId         String?
  course           Course?       @relation(fields: [courseId], references: [id])
  examType         ExamType?
  slot             String?
  year             Int?
  semester         Semester      @default(UNKNOWN)
  campus           Campus        @default(VELLORE)
  hasAnswerKey     Boolean       @default(false)
  questionPaperId  String?       @unique
  questionPaper    PastPaper?    @relation("PastPaperAnswerKeyLink", fields: [questionPaperId], references: [id], onDelete: SetNull)
  answerKeyVariant PastPaper?    @relation("PastPaperAnswerKeyLink")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  bookmarkedBy     User[]        @relation("UserBookmarkedPastPapers")
  viewHistory      ViewHistory[]
  studyChats       StudyChat[]

  @@index([isClear, createdAt])
  @@index([createdAt])
  @@index([authorId])
  @@index([courseId, examType])
  @@index([courseId, year])
  @@index([courseId, slot])
  @@index([courseId, isClear, createdAt])
  @@index([courseId, isClear, year, createdAt])
  @@index([courseId, isClear, examType, year, createdAt])
  @@index([courseId, isClear, examType, slot, year, semester, campus, hasAnswerKey, createdAt], map: "PastPaper_metadata_sibling_idx")
  @@index([isClear, examType, courseId, year, createdAt])
}

model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  aliases    String[]
  notes      Note[]
  forums     Forum[]
  forumPosts ForumPost[]
  pastPapers PastPaper[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([name], map: "Tag_name_trgm_idx")
}

model Subject {
  id           String        @id @default(cuid())
  name         String        @unique
  modules      Module[]
  bookmarkedBy User[]        @relation("UserBookmarkedResources")
  viewHistory  ViewHistory[]
}

model Module {
  id            String   @id @default(cuid())
  title         String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  subjectId     String
  webReferences String[]
  youtubeLinks  String[]

  @@index([subjectId])
}

model syllabi {
  id           String        @id @default(cuid())
  name         String
  fileUrl      String
  bookmarkedBy User[]        @relation("UserBookmarkedSyllabus")
  viewHistory  ViewHistory[]

  @@index([name])
}

enum StudyScope {
  NOTE
  PAST_PAPER
  COURSE
}

model StudyChat {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope       StudyScope
  noteId      String?
  note        Note?          @relation(fields: [noteId], references: [id], onDelete: SetNull)
  pastPaperId String?
  pastPaper   PastPaper?     @relation(fields: [pastPaperId], references: [id], onDelete: SetNull)
  courseCode  String?
  title       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  messages    StudyMessage[]

  @@index([userId, updatedAt])
  @@index([userId, noteId])
  @@index([userId, pastPaperId])
  @@index([userId, courseCode])
}

model StudyMessage {
  id        String    @id @default(cuid())
  chatId    String
  chat      StudyChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String
  parts     Json
  createdAt DateTime  @default(now())

  @@index([chatId, createdAt])
}

enum crdb_internal_region {
  aws_ap_south_1 @map("aws-ap-south-1")
}
